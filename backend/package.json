{
  "name": "blogging-app-backend",
  "version": "1.0.0",
  "description": "Production microservices backend",
  "private": true,
  "workspaces": [
    "services/*",
    "gateway",
    "shared",
    "services/chat"
  ],
  "scripts": {
    "auth:dev": "npm run dev -w services/auth",
    "blog:dev": "npm run dev -w services/blog",
    "gateway:dev": "npm run dev -w gateway",
    "dev": "npm run dev --workspaces"
  },
  "dependencies": {
    "mongoose": "^9.2.2",
    "jsonwebtoken": "^9.0.3",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "cors": "^2.8.6",
    "cookie-parser": "^1.4.7",
    "express-rate-limit": "^8.2.1",
    "slugify": "^1.6.6"
  }
}